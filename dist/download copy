                        saveBtn.classList.replace('bg-primary', 'bg-status-success');
                        setTimeout(() => {
                            saveBtn.innerHTML = 'Save Protocol';
                            saveBtn.classList.replace('bg-status-success', 'bg-primary');
                        }, 2000);
                    }, 1000);
                });
