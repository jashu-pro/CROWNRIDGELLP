<script>
        // Micro-interactions for Priority Buttons
        const priorityBtns = ['priority-low', 'priority-med', 'priority-high'];
        priorityBtns.forEach(id => {
            document.getElementById(id).addEventListener('click', function() {
                priorityBtns.forEach(btnId => {
                    const btn = document.getElementById(btnId);
                    btn.classList.remove('border-primary', 'bg-primary-container/10', 'text-primary', 'font-bold');
                    btn.classList.add('border-border-subtle', 'bg-transparent', 'text-on-surface-variant', 'font-medium');
                });
                this.classList.remove('border-border-subtle', 'bg-transparent', 'text-on-surface-variant', 'font-medium');
                this.classList.add('border-primary', 'bg-primary-container/10', 'text-primary', 'font-bold');
            });
        });

        // Simple Form Submission prevention for demo
        document.querySelector('form').addEventListener('submit', (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin" data-icon="progress_activity">progress_activity</span> Processing...';
            btn.disabled = true;
            
            setTimeout(() => {
                btn.innerHTML = '<span class="material-symbols-outlined" data-icon="check_circle">check_circle</span> Package Generated!';
                btn.classList.remove('bg-primary');
                btn.classList.add('bg-status-success');
                setTimeout(() => {
                    btn.innerHTML = originalText;
                    btn.classList.remove('bg-status-success');
                    btn.classList.add('bg-primary');
                    btn.disabled = false;
                }, 2000);
            }, 1500);
        });
    </script>
