<script>
        // Micro-interaction: Checkbox completion feedback
        document.querySelectorAll('.task-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const row = this.closest('.group');
                if (this.checked) {
                    row.classList.add('opacity-60');
                    row.classList.add('bg-surface-muted');
                } else {
                    row.classList.remove('opacity-60');
                    row.classList.remove('bg-surface-muted');
                }
            });
        });

        // Atmospheric effect: Subtle mouse movement on bento cards
        const bentoCards = document.querySelectorAll('.rounded-xl');
        bentoCards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                card.style.setProperty('--mouse-x', `${x}px`);
                card.style.setProperty('--mouse-y', `${y}px`);
            });
        });
    </script>
